<launch>

<rosparam file="$(find assembly_Final_urdf_made_of_description)/launch/controller.yaml" command="load"/>
<node name="controller_spawner" pkg="controller_manager" type="spawner" respawn="false" output="screen" ns="assembly_Final_urdf_made_of" args="L1_2_position_controller L1_1_position_controller L1_3_position_controller Revolute 59_position_controller Revolute 60_position_controller Revolute 61_position_controller Revolute 62_position_controller Revolute 63_position_controller Revolute 69_position_controller Revolute 70_position_controller Revolute 71_position_controller Revolute 72_position_controller Revolute 73_position_controller Revolute 80_position_controller Revolute 90_position_controller Revolute 92_position_controller Revolute 95_position_controller Revolute 97_position_controller joint_state_controller "/>
<node name="robot_state_publisher" pkg="robot_state_publisher" type="robot_state_publisher" respawn="false" output="screen">
  <remap from="/joint_states" to="/assembly_Final_urdf_made_of/joint_states"/>
</node>

</launch>